# 云棉环境变量示例
# 复制为 .env 后再填写真实值。不要提交包含密码或数据库连接串的 .env。

# --- 管理员 ---

# 初始管理员账号。管理员已创建后，修改这里不会重命名现有账号。
CHATGPT2API_ADMIN_USERNAME=admin

# 初始管理员密码。留空时首次启动会生成一次性密码并输出到容器日志。
# CHATGPT2API_ADMIN_PASSWORD=change_me_please

# --- 外部访问与上游 ---

# 图片访问地址，用于生成图片 URL 和 OAuth 回调地址，不要以斜杠结尾。
CHATGPT2API_BASE_URL=https://image.yunmian.tech

# API 访问地址，即请求转发到的 NewAPI 服务地址，不要以斜杠结尾。
CHATGPT2API_RELAY_BASE_URL=https://www.yunmian.tech

# NewAPI 数据库只读连接，仅用于用户登录和读取令牌；生产环境请使用只有 SELECT 权限的账号。
# CHATGPT2API_NEWAPI_DATABASE_URL=postgresql://readonly:password@postgres:5432/new-api?sslmode=disable

# 未选择 Key 名称时优先使用的 NewAPI 令牌分组；用户实际从本人可用 Key 名称中选择。
CHATGPT2API_NEWAPI_TOKEN_GROUP=gpt-image-2

# 全局代理，可选 http、https、socks5 或 socks5h。
# CHATGPT2API_PROXY=http://127.0.0.1:7890

# --- Docker 部署 ---

# 默认使用 Docker Hub 最新镜像；生产环境可改为固定版本，例如 1.0.0。
CHATGPT2API_IMAGE=mienvirtuoso/chatgpt2api:latest

# 已存在的反向代理 Docker 网络。
CHATGPT2API_DOCKER_NETWORK=newapi_default

# 容器时区。
TZ=Asia/Shanghai

# --- 运行策略（可选）---
# 下列设置均有程序默认值，也可以在管理端设置页修改；需要覆盖默认值时再取消注释。

# 限流账号检查间隔，单位分钟，默认 5。
# CHATGPT2API_REFRESH_ACCOUNT_INTERVAL_MINUTE=5

# 图片任务超时时间，单位秒，默认 300。
# CHATGPT2API_IMAGE_TASK_TIMEOUT_SECONDS=300

# 普通用户默认创作并发额度，0 表示不限制，默认 0。
# CHATGPT2API_USER_DEFAULT_CONCURRENT_LIMIT=0

# 普通用户默认创作任务 RPM，0 表示不限制，默认 0。
# CHATGPT2API_USER_DEFAULT_RPM_LIMIT=0

# 服务端缓存图片保留天数，默认 30。
# CHATGPT2API_IMAGE_RETENTION_DAYS=30

# 图片库容量上限，单位 MB；0 表示不按容量清理，默认 0。
# CHATGPT2API_IMAGE_STORAGE_LIMIT_MB=0

# 业务日志保留天数，默认 7。
# CHATGPT2API_LOG_RETENTION_DAYS=7

# 自动移除失效账号，默认 false。
# CHATGPT2API_AUTO_REMOVE_INVALID_ACCOUNTS=false

# 自动移除限流账号，默认 false。
# CHATGPT2API_AUTO_REMOVE_RATE_LIMITED_ACCOUNTS=false

# 记录的日志级别，多个值用英文逗号分隔；留空表示全部记录。
# CHATGPT2API_LOG_LEVELS=warning,error

# --- 本地存储 ---

# 存储后端：sqlite、postgres 或 mysql，默认 sqlite。
STORAGE_BACKEND=sqlite

# SQLite 默认使用 /app/data/chatgpt2api.db，无需设置 DATABASE_URL。
# PostgreSQL: DATABASE_URL=postgresql://user:password@host:5432/chatgpt2api
# MySQL:      DATABASE_URL=mysql://user:password@host:3306/chatgpt2api
